<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title><?js= title ?></title>

    <script src="scripts/prettify/prettify.js"> </script>
    <script src="scripts/prettify/lang-css.js"> </script>
    <link type="text/css" rel="stylesheet" href="styles/prettify-tomorrow.css">
    <link type="text/css" rel="stylesheet" href="styles/jsdoc-default.css">
</head>

<body>


<main>
    <nav>
        <?js= this.nav ?>
    </nav>
    <div id="main">
        <?js if (title === "Global") { ?>
            <h2 class="h-title"><?js= title ?></h2>
        <?js } ?>

        <?js= content ?>
        <footer>
            Documentation generated by <a href="https://github.com/jsdoc/jsdoc">JSDoc <?js= env.version.number ?></a><?js if(env.conf.templates && env.conf.templates.default && env.conf.templates.default.includeDate !== false) { ?> on <?js= new Date().toGMTString() ?><?js } ?>
        </footer>
    </div>
</main>

<br class="clear">

<script>
{
    const ovviews = document.querySelectorAll(".container-overview");
    for (const ov of ovviews) {
        if (ov.children.length === 1 && !ov.children[0].innerHTML.trim()) {
            ov.parentNode.removeChild(ov);
        }
    }
}

{
    let deletions = document.querySelectorAll("article > br:first-child");
    for (const e of deletions) { e.parentNode.removeChild(e); }
    deletions = document.querySelectorAll("article > br:first-child");
    for (const e of deletions) { e.parentNode.removeChild(e); }
    deletions = document.querySelectorAll("article > hr:first-child");
    for (const e of deletions) { e.parentNode.removeChild(e); }
    deletions = document.querySelectorAll("article > hr:last-child");
    for (const e of deletions) { e.parentNode.removeChild(e); }
}

prettyPrint();
</script>
<script src="scripts/linenumber.js"></script>
</body>
</html>
